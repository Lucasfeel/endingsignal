# Copy this file to `.env.sentry.local` and fill the values locally.
# Keep real secrets out of source control.

# Runtime capture for the Flask service.
SENTRY_API_DSN=
# Compatibility alias for backend services still reading SENTRY_DSN.
SENTRY_DSN=
# Browser/admin surfaces rendered by Flask templates.
SENTRY_FRONTEND_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=
SENTRY_API_RELEASE=
SENTRY_FRONTEND_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0.0
SENTRY_PROFILE_SESSION_SAMPLE_RATE=0.0
SENTRY_PROFILES_SAMPLE_RATE=0.0
SENTRY_FRONTEND_TRACES_SAMPLE_RATE=0.0
SENTRY_FRONTEND_REPLAYS_SESSION_SAMPLE_RATE=0.1
SENTRY_FRONTEND_REPLAYS_ON_ERROR_SAMPLE_RATE=1.0
SENTRY_SEND_DEFAULT_PII=0

# Codex + Sentry API triage access.
SENTRY_ACCESS_TOKEN=
# Compatibility alias. You can leave this blank if SENTRY_ACCESS_TOKEN is set.
SENTRY_AUTH_TOKEN=
SENTRY_ORG_SLUG=
# Use one project slug or a comma-separated list.
SENTRY_PROJECT_SLUG=
SENTRY_PROJECT_SLUGS=
EMBEDDED_AGENT_PROVIDER=openai
OPENAI_API_KEY=
SENTRY_HOST=
MCP_DISABLE_SKILLS=
SENTRY_ISSUE_QUERY=is:unresolved
SENTRY_ISSUE_SORT=freq
SENTRY_BASE_URL=https://sentry.io

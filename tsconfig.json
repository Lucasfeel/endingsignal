{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": false,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowJs": true,
    "types": [
      "vite/client",
      "vitest/globals"
    ]
  },
  "include": [
    "frontend/apps/**/*.ts",
    "frontend/apps/**/*.tsx",
    "frontend/src/**/*.ts",
    "frontend/src/**/*.tsx",
    "vite.config.ts"
  ]
}

{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "strict": false,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowJs": true,
    "types": [
      "vite/client"
    ]
  },
  "include": [
    "frontend/**/*.ts",
    "frontend/**/*.tsx",
    "vite.config.ts"
  ]
}
